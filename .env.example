# Root environment examples for local development.
# This repository mainly uses per-app env files:
# - api/.env
# - apps/web/.env

# Web client (copy relevant values to apps/web/.env)
VITE_API_BASE_URL=http://localhost:5050
VITE_API_URL=http://localhost:5050
VITE_TEST_MODE=false

# API reference (copy to api/.env)
MONGO_URI=mongodb://localhost:27017
DB_NAME=educational_platform
JWT_SECRET=dev-secret
BOOTSTRAP_ADMIN_KEY=
