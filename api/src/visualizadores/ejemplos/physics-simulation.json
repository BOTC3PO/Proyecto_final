{
  "id": "physics-simulation",
  "title": "Simulación de caída libre",
  "description": "Modelo de caída libre con parámetros configurables: altura inicial, masa y gravedad. Calcula tiempo y velocidad de impacto.",
  "spec": {
    "kind": "physics-simulation",
    "title": "Caída libre – Modelo cinemático",
    "description": "Un objeto cae desde una altura h₀ con velocidad inicial cero. Se calcula la posición y velocidad en función del tiempo.",
    "model": {
      "id": "caida-libre",
      "label": "Caída libre (sin rozamiento)",
      "equation": "y(t) = h₀ − ½·g·t²  |  v(t) = g·t",
      "assumptions": [
        "Rozamiento del aire despreciable",
        "Campo gravitacional uniforme",
        "Velocidad inicial = 0"
      ]
    },
    "parameters": [
      {
        "id": "h0",
        "label": "Altura inicial",
        "input": "number",
        "unit": "m",
        "min": 1,
        "max": 500,
        "step": 1,
        "value": 80,
        "description": "Altura desde la que se suelta el objeto"
      },
      {
        "id": "masa",
        "label": "Masa",
        "input": "number",
        "unit": "kg",
        "min": 0.1,
        "max": 100,
        "step": 0.1,
        "value": 2,
        "description": "Masa del objeto (no afecta el tiempo de caída sin rozamiento)"
      },
      {
        "id": "g",
        "label": "Gravedad",
        "input": "select",
        "unit": "m/s²",
        "value": "9.8",
        "options": [
          { "label": "Tierra (9.8 m/s²)", "value": "9.8" },
          { "label": "Luna (1.62 m/s²)", "value": "1.62" },
          { "label": "Marte (3.72 m/s²)", "value": "3.72" }
        ],
        "description": "Aceleración gravitacional del planeta"
      }
    ],
    "outputs": [
      {
        "id": "t_total",
        "label": "Tiempo de caída",
        "unit": "s",
        "value": 4.04,
        "description": "t = √(2·h₀/g)"
      },
      {
        "id": "v_impacto",
        "label": "Velocidad de impacto",
        "unit": "m/s",
        "value": 39.6,
        "description": "v = g·t = √(2·g·h₀)"
      },
      {
        "id": "ec_impacto",
        "label": "Energía cinética al impacto",
        "unit": "J",
        "value": 1568,
        "description": "Ec = ½·m·v²"
      }
    ],
    "series": [
      {
        "id": "posicion",
        "label": "Posición y(t)",
        "unit": "m",
        "color": "#2563eb",
        "data": [
          {"t": 0.0, "value": 80},
          {"t": 0.5, "value": 78.8},
          {"t": 1.0, "value": 75.1},
          {"t": 1.5, "value": 68.9},
          {"t": 2.0, "value": 60.4},
          {"t": 2.5, "value": 49.4},
          {"t": 3.0, "value": 35.9},
          {"t": 3.5, "value": 19.9},
          {"t": 4.0, "value": 1.6},
          {"t": 4.04, "value": 0}
        ]
      },
      {
        "id": "velocidad",
        "label": "Velocidad v(t)",
        "unit": "m/s",
        "color": "#f97316",
        "data": [
          {"t": 0.0, "value": 0},
          {"t": 0.5, "value": 4.9},
          {"t": 1.0, "value": 9.8},
          {"t": 1.5, "value": 14.7},
          {"t": 2.0, "value": 19.6},
          {"t": 2.5, "value": 24.5},
          {"t": 3.0, "value": 29.4},
          {"t": 3.5, "value": 34.3},
          {"t": 4.0, "value": 39.2},
          {"t": 4.04, "value": 39.6}
        ]
      }
    ],
    "notes": [
      "La masa no influye en el tiempo de caída ni en la posición (Galileo).",
      "En la Luna, el mismo objeto tarda ~9.9 s en caer desde 80 m."
    ]
  }
}
