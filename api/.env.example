# ================================
# API environment variables
# Copy to api/.env and adjust values
# ================================

# Runtime
NODE_ENV=development
PORT=5050
CORS_ORIGIN=http://localhost:5173

# Database
DB_KIND=mongo
MONGO_URI=mongodb://localhost:27017
DB_NAME=educational_platform

# Mongo connection hardening
MONGO_TLS=false
MONGO_REQUIRE_TLS=true
MONGO_CA_FILE=
MONGO_CERT_FILE=
MONGO_APP_NAME=educational-platform-api
MONGO_MAX_POOL_SIZE=10
MONGO_MIN_POOL_SIZE=0
MONGO_SERVER_SELECTION_MS=5000
MONGO_REQUIRE_AUTH=true

# SQLite dictionary mode (used when DB_KIND=sqlite)
SQLITE_PATH=./data/diccionario.sqlite
SQLITE_READONLY=true
SQLITE_CACHE_KB=65536

# Maps/content SQLite (for /api/maps)
CONTENT_SQLITE_PATH=./src/maps/geonames_index.sqlite

# Auth and bootstrap (set secure values in non-dev environments)
JWT_SECRET=dev-secret
JWT_REFRESH_SECRET=
JWT_ISSUER=
JWT_AUDIENCE=
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=0
BOOTSTRAP_ADMIN_KEY=

# Request and security controls
MAX_PAGE_MB=30
AUTH_RATE_LIMIT_DISABLED=false
ENABLE_SEED_ENDPOINT=false

# Payments
PAYMENTS_WEBHOOK_SECRET=

# Billing/governance knobs
BILLING_PAST_DUE_DAYS=7
BILLING_SUSPEND_DAYS=30
BILLING_DELINQUENCY_JOB_INTERVAL_MINUTES=60
BILLING_DELINQUENCY_JOB_ENABLED=true
GOV_CONTENT_MIN_YES=1
GOV_CONTENT_YES_GT_NO=true
GOV_GOVERNANCE_RULE=SUPERMAJORITY_2_3

# Optional script defaults
AUTH_HEALTH_EMAIL=admin@escuela.com
ADMIN_USERNAME=admin.escuela
